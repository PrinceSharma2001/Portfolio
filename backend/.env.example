# Copy this file to .env and fill in your local PostgreSQL details
PORT=5000

# Option 1: individual fields
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=portfolio_db

# Option 2: OR just set a single connection string instead of the 5 fields above
# DATABASE_URL=postgres://postgres:your_postgres_password@localhost:5432/portfolio_db

# Simple key the developer must send to view messages (change this!)
ADMIN_KEY=change_this_secret_key
